NODE_ENV=development
PORT=8787
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:5173,https://caribbean-one.site,https://www.caribbean-one.site

# STUN/TURN. In production, point both entries to the EC2/domain running coturn.
STUN_URLS=stun:turn.caribbean-one.site:3478
TURN_URLS=turn:turn.caribbean-one.site:3478?transport=udp,turn:turn.caribbean-one.site:3478?transport=tcp
TURN_SHARED_SECRET=replace-with-a-long-random-secret
TURN_CREDENTIAL_TTL_SECONDS=3600

MAX_ROOM_PARTICIPANTS=2
MAX_MESSAGE_BYTES=65536
MAX_MESSAGES_PER_WINDOW=120
RATE_LIMIT_WINDOW_MS=10000

# Helios SFU (LiveKit). Secrets are server-only and must never be exposed to Vite.
LIVEKIT_API_URL=http://127.0.0.1:7880
LIVEKIT_WS_URL=wss://rtc.caribbean-one.site
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_TOKEN_TTL_SECONDS=3600
LIVEKIT_MAX_PARTICIPANTS=10
